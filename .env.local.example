# ──────────────────────────────────────────────
# Ghost CMS — Headless Integration
# Copy this file to .env.local and replace the values below
# ──────────────────────────────────────────────

# ── Local Development (Docker) ────────────────
# Start Ghost with: docker compose up -d
# Open the admin panel at: http://localhost:2368/ghost
# Admin → Settings → Integrations → Add Custom Integration → copy the Content API Key

GHOST_URL=http://localhost:2368
GHOST_CONTENT_API_KEY=your-ghost-content-api-key

# Admin API Key — server-side only (never expose it to the client)
# Ghost Admin → Integrations → Your Integration → Admin API Key
GHOST_ADMIN_API_KEY=your-ghost-admin-api-key

# ── Production ────────────────────────────────
# GHOST_URL=https://blog.example.org
# GHOST_CONTENT_API_KEY=your-production-content-api-key

# Public Next.js URL (used for canonical URLs, Open Graph tags, and JSON-LD)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://example.org

# ── Resend (Contact Form) ─────────────────────
# Create an account at https://resend.com and generate an API key
RESEND_API_KEY=your-resend-api-key

# Verified sender email address in Resend (e.g. noreply@example.org)
RESEND_FROM_EMAIL=noreply@example.org

# Email address that will receive contact form submissions
RESEND_TO_EMAIL=contact@example.org