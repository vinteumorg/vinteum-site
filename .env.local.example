# ──────────────────────────────────────────────
# Ghost CMS — Headless Integration
# Copie este arquivo para .env.local e preencha os valores
# ──────────────────────────────────────────────

# ── Desenvolvimento local (Docker) ────────────
# Suba o Ghost com: docker compose up -d
# Acesse o admin em: http://localhost:2368/ghost
# Admin → Settings → Integrations → Add custom integration → copie o Content API Key

GHOST_URL=http://localhost:2368
GHOST_CONTENT_API_KEY=seu_content_api_key_aqui
# Admin API Key — somente server-side (nunca expor no client)
# Ghost Admin → Integrations → sua integração → Admin API Key
GHOST_ADMIN_API_KEY=id_hex:secret_hex

# ── Produção ──────────────────────────────────
# GHOST_URL=https://blog.vinteum.org
# GHOST_CONTENT_API_KEY=seu_key_de_producao_aqui

# URL pública do Next.js (para canonical, OG tags e JSON-LD)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Produção: NEXT_PUBLIC_SITE_URL=https://vinteum.org
